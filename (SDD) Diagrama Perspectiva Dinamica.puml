@startuml
title  Iteración del proceso híbrido OpenUP / Scrum / SDD

' === Modern soft theme ===
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Helvetica
skinparam defaultFontSize 11
skinparam titleFontSize 16
skinparam titleFontStyle bold
skinparam shadowing false
skinparam roundCorner 14
skinparam linetype polyline

skinparam activity {
    BackgroundColor       #B0DFE8
    BorderColor           #7DB9C5
    FontColor             #0F3539
    FontName              Helvetica
    FontSize              11
    DiamondBackgroundColor #F4E2A0
    DiamondBorderColor    #C9B05E
    DiamondFontColor      #3A2E0A
    StartColor            #6B7280
    EndColor              #6B7280
    BarColor              #6B7280
}

skinparam partition {
    BackgroundColor #FFFFFF
    BorderColor     #C9C9BE
    FontColor       #4A4A48
    FontStyle       bold
    FontSize        12
}

skinparam arrow {
    Color     #6B7280
    FontColor #4A4A48
    FontSize  10
    Thickness 1
}

skinparam note {
    BackgroundColor #FFF8E1
    BorderColor     #C9B05E
    FontColor       #3A2E0A
}

!define Dev Desarrollador  
!define Coo Coordinador IA
!define SubRed Subagente\nRedactor
!define SubDis Subagente\nde Diseño
!define SubImp Subagente\nde Implementación
!define SubVer Subagente\nVerificador
!define Tes Tester

|Dev|
|Coo|
|SubRed|
|SubDis|
|SubImp|
|SubVer|

' PIPELINE SDD
|Dev|
:Entregar\nCaso de Uso;
|Coo|
:Consultar Memoria Persistente;
:Instanciar Subagente Redactor;
|SubRed|
:Genera Spec Ejecutable;
|Dev|
:Verifica Spec Ejecutable;
if (¿La spec es técnicamente viable?) then (No)
    repeat
        |Dev|
        :Comunicar observaciones;
        |Coo|
        :Reinstanciar Redactor con observaciones;
        |SubRed|
        :Genera Spec Ejecutable actualizada;
        |Dev|
    repeat while (¿La spec es técnicamente viable?) is (No) not (Sí)
else (Sí)
endif

|Coo|
:Instanciar Subagente de Diseño;
|SubDis|
:Genera Diseño Detallado;
|Dev|
if (<center>¿Respeta los ADRs registrados\ny es consistente con\nla arquitectura base?) then (No)
    repeat
        |Dev|
        :Comunicar observaciones;
        |Coo|
        :Reinstanciar Subagente de Diseño con observaciones;
        |SubDis|
        :Genera Diseño Detallado actualizado;
        |Dev|
    repeat while (<center>¿Respeta los ADRs registrados\ny es consistente con\nla arquitectura base?) is (No) not (Sí)
else (Sí)
endif

|Coo|
:Instanciar Subagente de Implementación;
|SubImp|
:Genera Código Fuente;
|Dev|
if (<center>¿Respeta las convenciones\nde código e implementa\ncorrectamente el diseño?) then (No)
    repeat
        |Dev|
        :Comunicar observaciones;
        |Coo|
        :Reinstanciar Subagente de Implementación con observaciones;
        |SubImp|
        :Genera Código Fuente actualizado;
        |Dev|
    repeat while (<center>¿Respeta las convenciones\nde código e implementa\ncorrectamente el diseño?) is (No) not (Sí)
else (Sí)
endif

|Coo|
:Instanciar Subagente Verificador;
|SubVer|
:Genera Tests Automatizados;
:Ejecuta los tests contra el código;
:Genera Reporte de Validación;
|Dev|
if (<center>¿Todos los criterios están cubiertos?) then (No)
    repeat
        |Dev|
        :Comunicar observaciones;
        |Coo|
        :Reinstanciar Subagente Verificador con observaciones;
        |SubVer|
        :Ejecuta los tests actualizados contra el código;
        :Genera Reporte de Validación actualizado;
        |Dev|
        repeat
            |Dev|
            :Comunicar observaciones;
            |Coo|
            :Reinstanciar Subagente de Implementación;
            |SubImp|
            :Gegenera Código Fuente actualizado;
            |SubVer|
            :Ejecuta los tests contra el código actualizado;
            :Genera Reporte de Validación;
            |Dev|
        repeat while (<center>¿Los tests se ejecutaron\nexitosamente?) is (No) not (Sí)
    repeat while (<center>¿Todos los criterios están cubiertos?) is (No) not (Sí)
else (Sí)
endif
:ToDo: Definition of Done;
stop
@enduml