title: "11.c — Clases de diseño · Patrones State y Observer sobre Contratación"
---
classDiagram
    class Contratacion {
        - id
        - fechaSolicitud
        - estado : EstadoContratacion
        - observadores : Observador[*]
        + solicitar()
        + aceptar()
        + iniciar()
        + finalizar()
        + cancelar()
        + setEstado(e : EstadoContratacion)
        + suscribir(o : Observador)
        - notificar()
    }

    class EstadoContratacion {
        <<abstract>>
        + aceptar(c : Contratacion)
        + iniciar(c : Contratacion)
        + finalizar(c : Contratacion)
        + cancelar(c : Contratacion)
    }

    class Solicitada
    class Confirmada
    class EnCurso
    class Finalizada
    class Cancelada

    class Observador {
        <<interface>>
        + actualizar(c : Contratacion)
    }

    class NotificadorCliente
    class NotificadorPrestador

    EstadoContratacion <|-- Solicitada
    EstadoContratacion <|-- Confirmada
    EstadoContratacion <|-- EnCurso
    EstadoContratacion <|-- Finalizada
    EstadoContratacion <|-- Cancelada

    Observador <|.. NotificadorCliente
    Observador <|.. NotificadorPrestador

    Contratacion "«State» Context" o--> "estado actual" EstadoContratacion
    Contratacion "«Observer» Subject" o--> "observadores" Observador