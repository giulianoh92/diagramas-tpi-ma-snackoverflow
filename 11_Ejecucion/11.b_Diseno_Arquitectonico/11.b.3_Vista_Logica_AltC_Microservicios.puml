@startuml
title 11.b — Vista lógica · Alternativa C: Microservicios orientados a eventos (Event-Driven + API Gateway + Broker)

!include ../../00_Comun/00.0_Estilo_Comun.iuml

skinparam componentStyle uml2

actor "Cliente / Prestador\n/ Administrador" as Usuario

package "Capa de Presentación" as P {
  component "SPA Next.js + React\n(patrón MVC)" as SPA
}

component "API Gateway" as GW

package "Servicios independientes (database-per-service)" as SVCS {
  component "Servicio\nUsuarios" as SUsr
  database "DB Usuarios" as DBu
  component "Servicio\nCatálogo" as SCat
  database "DB Catálogo" as DBc
  component "Servicio\nContratación" as SCon
  database "DB Contratación" as DBn
  component "Servicio\nPagos" as SPag
  database "DB Pagos" as DBp
  component "Servicio\nReputación" as SRep
  database "DB Reputación" as DBr
  component "Servicio\nHabilitaciones" as SHab
  database "DB Habilitac." as DBh
  component "Servicio\nNotificaciones" as SNot
}

queue "Bus de eventos\n(Message Broker)" as BUS

cloud "Mercado Pago" as MP <<sistema externo>>
cloud "Proveedor de\nMensajería" as MS <<sistema externo>>
cloud "Organismo\nRegulador" as OR <<sistema externo>>

Usuario --> SPA
SPA --> GW : API REST
GW --> SUsr
GW --> SCat
GW --> SCon
GW --> SPag
GW --> SRep
GW --> SHab

SUsr --> DBu
SCat --> DBc
SCon --> DBn
SPag --> DBp
SRep --> DBr
SHab --> DBh

' Comunicación asíncrona por eventos
SCon ..> BUS
SPag ..> BUS
SHab ..> BUS
BUS ..> SNot
BUS ..> SRep

SPag --> MP
SNot --> MS
SHab --> OR

note bottom of SVCS
  Escalado y despliegue independientes por servicio (RNF-E.2);
  aísla fallos y seguridad por dominio. Penaliza la simplicidad y
  el uptime operacional (más piezas, consistencia eventual): costo
  difícil de justificar para un equipo pequeño (alternativa de contraste).
end note
@enduml
