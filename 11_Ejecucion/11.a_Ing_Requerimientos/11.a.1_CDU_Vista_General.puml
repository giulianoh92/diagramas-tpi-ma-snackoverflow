@startuml
title Casos de Uso — Vista general (modelo del documento)
left to right direction

' === Modern soft theme ===
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Helvetica
skinparam defaultFontSize 11
skinparam titleFontSize 16
skinparam titleFontStyle bold
skinparam shadowing false
skinparam roundCorner 14
skinparam nodesep 25
skinparam ranksep 40
skinparam linetype polyline

skinparam usecase {
    BackgroundColor       #C9DFEE
    BorderColor           #000000
    FontColor             #000000
    FontName              Helvetica
    FontSize              11
}

skinparam actor {
    BackgroundColor       #C9DFEE
    BorderColor           #000000
    FontColor             #000000
    FontName              Helvetica
    FontSize              11
}

skinparam actor<<sistema externo>> {
    BackgroundColor       #EFE3C8
    BorderColor           #000000
}

skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor     #C9C9BE
    FontColor       #4A4A48
    FontStyle       bold
    FontSize        12
}

skinparam arrow {
    Color     #090D10
    FontColor #090D10
    FontSize  10
    Thickness 1
}

skinparam note {
    BackgroundColor #FFF8E1
    BorderColor     #C9B05E
    FontColor       #3A2E0A
}

actor Cliente as C
actor Prestador as P
actor Administrador as A
actor "Pasarela\nde Pagos" as PP <<sistema externo>>
actor "Organismo\nRegulador" as OR <<sistema externo>>

rectangle "Plataforma de Economía Colaborativa Basada en Oficios" {
  usecase "UC01\nRegistrarse" as UC01
  usecase "UC02\nAutenticarse" as UC02
  usecase "UC03\nGestionar perfil" as UC03
  usecase "UC04\nBuscar prestadores" as UC04
  usecase "UC05\nPublicar servicios" as UC05
  usecase "UC06\nGestionar agenda\ny disponibilidad" as UC06
  usecase "UC07\nSolicitar contratación" as UC07
  usecase "UC08\nResponder solicitud\n(aceptar / rechazar / alternativa)" as UC08
  usecase "UC09\nGestionar estados\nde la contratación" as UC09
  usecase "UC10\nCancelar contratación" as UC10
  usecase "UC11\nIntercambiar mensajes" as UC11
  usecase "UC12\nPagar servicio" as UC12
  usecase "UC13\nConfirmar finalización\ny liberar pago" as UC13
  usecase "UC14\nCalificar prestador" as UC14
  usecase "UC15\nResponder reseña" as UC15
  usecase "UC16\nModerar reseñas" as UC16
  usecase "UC17\nGestionar perfiles\n(suspensión / baja)" as UC17
  usecase "UC18\nVerificar habilitaciones\nprofesionales" as UC18
  usecase "UC19\nNotificar cambio\nde estado" as UC19
}

C --> UC01
C --> UC03
C --> UC04
C --> UC07
C --> UC10
C --> UC11
C --> UC12
C --> UC14

P --> UC01
P --> UC03
P --> UC05
P --> UC06
P --> UC08
P --> UC10
P --> UC11
P --> UC13
P --> UC15

A --> UC16
A --> UC17
A --> UC18

UC03 ..> UC02 : <<include>>
UC05 ..> UC02 : <<include>>
UC06 ..> UC02 : <<include>>
UC07 ..> UC02 : <<include>>
UC08 ..> UC02 : <<include>>
UC10 ..> UC02 : <<include>>
UC11 ..> UC02 : <<include>>
UC12 ..> UC02 : <<include>>
UC13 ..> UC02 : <<include>>
UC14 ..> UC02 : <<include>>
UC15 ..> UC02 : <<include>>
UC16 ..> UC02 : <<include>>
UC17 ..> UC02 : <<include>>
UC18 ..> UC02 : <<include>>
UC19 ..> UC09 : <<extend>>

UC12 --> PP
UC13 --> PP
UC18 --> OR
@enduml
