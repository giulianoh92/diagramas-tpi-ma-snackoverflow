@startuml
title Casos de Uso — Contratación, ciclo de estados y mensajería (RF-5, RF-6)
left to right direction

!include ../../00_Comun/00.0_Estilo_Comun.iuml

actor Cliente as C
actor Prestador as P

rectangle "Plataforma de Economía Colaborativa Basada en Oficios" {
  usecase "UC02\nAutenticarse" as UC02
  usecase "UC07\nSolicitar contratación" as UC07
  usecase "UC08\nResponder solicitud\n(aceptar / rechazar / alternativa)" as UC08
  usecase "UC09\nGestionar estados\nde la contratación" as UC09
  usecase "UC10\nCancelar contratación" as UC10
  usecase "UC11\nIntercambiar mensajes" as UC11
  usecase "UC19\nNotificar cambio\nde estado" as UC19
}

C --> UC07
P --> UC08
C --> UC10
P --> UC10
C --> UC11
P --> UC11

UC07 ..> UC02 : <<include>>
UC08 ..> UC02 : <<include>>
UC10 ..> UC02 : <<include>>
UC11 ..> UC02 : <<include>>
UC19 ..> UC09 : <<extend>>

note bottom of UC09
  Comportamiento del sistema: centraliza la
  máquina de estados de la contratación.
  Las transiciones se disparan desde UC07,
  UC08, UC10 y UC13. Detalle en la
  especificación de UC09.
end note
@enduml
