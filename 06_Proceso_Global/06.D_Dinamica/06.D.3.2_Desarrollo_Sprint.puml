@startuml
skinparam dpi 200
title  Meta-Modelo Del Proceso De Desarrollo de Sprint

' === Modern soft theme ===
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Helvetica
skinparam defaultFontSize 11
skinparam titleFontSize 16
skinparam titleFontStyle bold
skinparam shadowing false
skinparam roundCorner 14
skinparam linetype polyline

skinparam activity {
    BackgroundColor       #C9DFEE
    BorderColor           #000000
    FontColor             #000000
    FontName              Helvetica
    FontSize              11
    DiamondBackgroundColor #D9C2E3
    DiamondBorderColor    #000000
    DiamondFontColor      #000000
    StartColor            #000000
    EndColor              #000000
    BarColor              #000000
}

skinparam partition {
    BackgroundColor #FFFFFF
    BorderColor     #C9C9BE
    FontColor       #4A4A48
    FontStyle       bold
    FontSize        12
}

skinparam arrow {
    Color     #090D10
    FontColor #090D10
    FontSize  10
    Thickness 1
}

skinparam note {
    BackgroundColor #FFF8E1
    BorderColor     #C9B05E
    FontColor       #3A2E0A
}

!define ProMan <center>Project\nManager
!define ProManAna <center>Project\nManager\n+ Analista
!define Ana <center>Analista
!define AnaArq <center>Analista\n+ Arquitecto
!define Arq <center>Arquitecto
!define Dev <center>Desarrollador
!define Tes <center>Tester

start
repeat
    :<center>Seleccionar Work\nItem Pendiente;
    :<center>Dividir Work Item\nen Micro-incrementos;
    repeat
        :<center>Ejecutar\nPipeline SDD;
        note left:<center>Se desarrolla en\nel Meta-Modelo de\nPipeline SDD
        :<center>Integración del Micro-incremento\nal producto de Work Item;
        :<center>Verificación de\nla integración;
    repeat while (<center>¿Micro-incrementos\npendientes?) is (Si) not (No)
    :<center>Integración del Work Item\nal producto del Sprint;
    :<center>Verificación de\nla integración;
repeat while (<center>¿Work Items pendientes\nen Sprint?) is (Si) not (No)

:<center>Integración del Sprint\nal Producto Continuo;
:<center>Verificación de\nla integración;
fork
    :<center>Actualizar Work\nItem List;
fork again
    :<center>Actualizar Lista\nde Riesgos;
fork again
    :<center>Registrar decisiones\nen Memoria Persistente;
end fork

stop

@enduml
