@startuml
title Meta-modelo de la Disciplina de Ingeniería de Requisitos

skinparam backgroundColor #FAFAFA
skinparam defaultFontName Helvetica
skinparam defaultFontSize 11
skinparam titleFontSize 16
skinparam titleFontStyle bold
skinparam shadowing false
skinparam roundCorner 14
skinparam linetype polyline

skinparam activity {
    BackgroundColor #B0DFE8
    BorderColor #7DB9C5
    FontColor #0F3539
    FontName Helvetica
    FontSize 11
    DiamondBackgroundColor #F4E2A0
    DiamondBorderColor #C9B05E
    DiamondFontColor #3A2E0A
    StartColor #6B7280
    EndColor #6B7280
    BarColor #6B7280
}

skinparam partition {
    BackgroundColor #FFFFFF
    BorderColor #C9C9BE
    FontColor #4A4A48
    FontStyle bold
    FontSize 12
}

skinparam arrow {
    Color #6B7280
    FontColor #4A4A48
    FontSize 10
    Thickness 1
}

skinparam note {
    BackgroundColor #FFF8E1
    BorderColor #C9B05E
    FontColor #3A2E0A
}

|Analista|
|ProjectManager|

' === FASE CONCEPTION ===

|Analista|

:<center>Generar Documento\nde Visión;

:<center>Generar Glosario\nde Dominio;

:<center>Identificar Casos de Uso\nprincipales;

|ProjectManager|

:<center>Generar Lista\nde Riesgo inicial;

:<center>Crear Work\nItem List inicial;

' === FASE CONSTRUCTION (loop por Sprint) ===

repeat

|Analista|

:<center>Seleccionar Work\nItem pendiente;

:<center>Detallar Caso de Uso\ncorrespondiente al Work Item;

note right:<center>Dispara el pipeline SDD\n(ver Meta-modelo punto 6)

if (<center>¿Feedback\nReport?) then (Sí)

if (<center>¿Es nuevo\nrequisito?) then (Sí)

:<center>Elaborar nuevo\nCaso de Uso;

else (No)

note right:<center>Se trata como defecto\nen el próximo Sprint

endif

else (No)

endif

|ProjectManager|

:<center>Actualizar Work\nItem List;

|Analista|

:<center>Actualizar Lista\nde Riesgos;

repeat while (<center>¿Work Item\nList vacía?) is (No) not (Sí)

stop
@enduml