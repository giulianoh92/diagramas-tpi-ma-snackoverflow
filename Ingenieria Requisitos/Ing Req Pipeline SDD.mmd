@startuml
title Pipeline SDD – Ingeniería de Requerimientos

' === Mismo tema que el resto del repo ===

skinparam backgroundColor #FAFAFA
skinparam defaultFontName Helvetica
skinparam defaultFontSize 11
skinparam titleFontSize 16
skinparam titleFontStyle bold
skinparam shadowing false
skinparam roundCorner 14
skinparam linetype polyline

skinparam activity {
    BackgroundColor #B0DFE8
    BorderColor #7DB9C5
    FontColor #0F3539
    FontName Helvetica
    FontSize 11
    DiamondBackgroundColor #F4E2A0
    DiamondBorderColor #C9B05E
    DiamondFontColor #3A2E0A
    StartColor #6B7280
    EndColor #6B7280
    BarColor #6B7280
}

skinparam partition {
    BackgroundColor #FFFFFF
    BorderColor #C9C9BE
    FontColor #4A4A48
    FontStyle bold
    FontSize 12
}

skinparam arrow {
    Color #6B7280
    FontColor #4A4A48
    FontSize 10
    Thickness 1
}

skinparam note {
    BackgroundColor #FFF8E1
    BorderColor #C9B05E
    FontColor #3A2E0A
}

|Analista|
|Coordinador IA|
|Subagente Redactor|

|Analista|

:<center>Entregar Caso de Uso\nelaborado;

|Coordinador IA|

:<center>Consultar Memoria\nPersistente;

:<center>Instanciar Subagente\nRedactor;

|Subagente Redactor|

:<center>Genera Especificación Ejecutable\n(contexto · requisitos · restricciones\n· criterios de aceptación);

|Analista|

:<center>Revisar Especificación\nEjecutable;

if (<center>¿La spec es\ncorrecta y completa?) then (<center>No)

repeat

|Analista|

:<center>Comunicar\nobservaciones;

|Coordinador IA|

:<center>Reinstanciar Redactor\ncon observaciones;

|Subagente Redactor|

:<center>Genera Especificación\nEjecutable actualizada;

|Analista|

:<center>Revisar Especificación\nEjecutable;

repeat while (<center>¿La spec es\ncorrecta y completa?) is (<center>No) not (<center>Sí)

else (<center>Sí)

endif

|Coordinador IA|

:<center>Persistir Especificación\nen Memoria Persistente;

|Analista|

:<center>Agregar Work Item\na Work Item List;

stop
@enduml