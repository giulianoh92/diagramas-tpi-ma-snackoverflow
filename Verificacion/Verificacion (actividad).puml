@startuml
title Verificación

' === Modern soft theme ===
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Helvetica
skinparam defaultFontSize 11
skinparam titleFontSize 16
skinparam titleFontStyle bold
skinparam shadowing false
skinparam roundCorner 14
skinparam nodesep 25
skinparam ranksep 40
skinparam linetype polyline

skinparam activity {
    BackgroundColor       #B0DFE8
    BorderColor           #7DB9C5
    FontColor             #0F3539
    FontName              Helvetica
    FontSize              11
    DiamondBackgroundColor #F4E2A0
    DiamondBorderColor    #C9B05E
    DiamondFontColor      #3A2E0A
    StartColor            #6B7280
    EndColor              #6B7280
    BarColor              #6B7280
}

skinparam partition {
    BackgroundColor #FFFFFF
    BorderColor     #C9C9BE
    FontColor       #4A4A48
    FontStyle       bold
    FontSize        12
}

skinparam arrow {
    Color     #6B7280
    FontColor #4A4A48
    FontSize  10
    Thickness 1
}

skinparam note {
    BackgroundColor #FFF8E1
    BorderColor     #C9B05E
    FontColor       #3A2E0A
}
!define ProDes <center>Proceso de Desarrollo
!define SubVer <center>Subagente Verificador
!define CI <center>CI/CD
!define Tes <center>Tester
|ProDes|
|SubVer|
|CI|
|Tes|

|ProDes|
start
repeat
    :Comenzar sprint;
    repeat
        :Seleccionar Work Item;
        repeat
            :Realizar micro-incremento;
            |SubVer|
            :Test Unitario;
            |ProDes|
        repeat while (¿Micro-incrementos pendientes?) is (Si) not (No) 
        :Completar Work Item;
        |CI|
        :Test de Integración;
        |ProDes|
    repeat while (¿Work Items pendientes?) is (Si) not (No)
    :Integración continua del incremento;
    |Tes|
    :Test de Sistema;
    |ProDes|
repeat while (¿Sprints pendientes?) is (Si) not (No)

stop
@enduml